# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.local.example
!.env.example

# vercel
.vercel

# build-time generated type cards (re-built on every deploy)
/public/cards/

# typescript
*.tsbuildinfo
next-env.d.ts

# brainstorming tool runtime cache
.superpowers/

# source fonts (subset 后的 woff 入仓,源 OTF/TTF 不入)
scripts/NotoSansSC-*.otf
scripts/NotoSansSC-*.ttf
